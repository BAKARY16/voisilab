# =============================================================================
# VoisiLab – Variables d'environnement (PRODUCTION)
# Copiez ce fichier en .env et renseignez toutes les valeurs
#   cp .env.example .env
# =============================================================================

# ─── Domaines publics ─────────────────────────────────────────────────────────
# Utilisés par Traefik et par les services pour se référencer entre eux
NEXT_PUBLIC_API_URL=https://api.fablab.voisilab.online
VITE_API_URL=https://api.fablab.voisilab.online

# ─── Base de données MySQL (cPanel / phpMyAdmin externe) ──────────────────────
DATABASE_HOST=your-cpanel-mysql-host       # ex: 185.x.x.x ou mysql.yourhost.com
DATABASE_PORT=3306
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password_here
DATABASE_NAME=your_db_name

# ─── Authentification JWT (backend) ──────────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_SECRET=change_me_with_a_very_long_random_secret_64_chars_minimum
JWT_EXPIRES_IN=7d

# ─── CORS – origines autorisées par l'API ────────────────────────────────────
ALLOWED_ORIGINS=https://fablab.voisilab.online,https://admin.fablab.voisilab.online

# ─── EmailJS (notifications envoyées par le backend) ─────────────────────────
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
EMAILJS_TEMPLATE_CONTACT=template_contact_id
EMAILJS_TEMPLATE_PROJECT=template_project_id
ADMIN_NOTIFICATION_EMAIL=fablab@uvci.edu.ci

# ─── EmailJS (utilisé côté front-end Next.js – variables publiques) ──────────
# Ces valeurs sont embarquées dans le bundle au moment du build Docker
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
NEXT_PUBLIC_EMAILJS_RECIPIENT_EMAIL=fablab@uvci.edu.ci
NEXT_PUBLIC_EMAILJS_TEMPLATE_TEAM=template_team_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_CLIENT=template_client_id

# ─── Resend (API email pour les soumissions de projet côté Next.js) ───────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
